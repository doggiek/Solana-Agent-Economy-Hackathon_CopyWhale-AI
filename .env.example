# GoldRush API key
COVALENT_API_KEY=

# Recommended: use Helius Enhanced Transactions as the primary trade feed.
# HELIUS_API_KEY=YOUR_HELIUS_KEY

# Recommended: use a dedicated Solana RPC such as Helius instead of the public endpoint.
# Example:
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
# If your provider requires header auth, also set:
# SOLANA_RPC_API_KEY=YOUR_RPC_KEY
# Example for Tatum:
# SOLANA_RPC_URL=https://solana-mainnet.gateway.tatum.io
# SOLANA_RPC_API_KEY=YOUR_TATUM_KEY
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
